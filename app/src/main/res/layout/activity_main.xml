<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#111111"
        android:padding="22dp"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SHADOWCHAT"
            android:textColor="#FF004C"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="#00FF00"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ENCRYPTION PROTOCOL: AES-128-ECB"
                android:textColor="#888888"
                android:textSize="11sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

    </LinearLayout>

    <!-- CHAT AREA -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@id/securityNote"
        android:padding="16dp"
        android:clipToPadding="false"
        android:scrollbarThumbVertical="@null">

        <LinearLayout
            android:id="@+id/chatLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </ScrollView>

    <!-- SECURITY NOTE -->
    <TextView
        android:id="@+id/securityNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/inputArea"
        android:padding="8dp"
        android:text="[SECURITY NOTE] This prototype uses a hardcoded key. Real apps should use Android Keystore."
        android:textColor="#444444"
        android:textSize="10sp"
        android:textAlignment="center"
        android:fontFamily="monospace"/>

    <!-- INPUT AREA -->
    <LinearLayout
        android:id="@+id/inputArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="#111111"
        android:padding="14dp"
        android:elevation="12dp">

        <EditText
            android:id="@+id/messageInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="ENTER SHADOW MESSAGE..."
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="@drawable/bg_input_field"
            android:padding="14dp"
            android:fontFamily="monospace"
            android:textSize="14sp"/>

        <ImageButton
            android:id="@+id/sendButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@android:drawable/ic_menu_send"
            android:tint="#FFFFFF"
            android:background="@drawable/bg_button_send"
            android:layout_marginStart="10dp"
            android:contentDescription="Send"/>

    </LinearLayout>

</RelativeLayout>