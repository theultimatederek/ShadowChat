<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="start"
    android:padding="8dp">

    <TextView
        android:id="@+id/textSender"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SHADOW_AGENT"
        android:textColor="#888888"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="4dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bubble_received"
        android:padding="12dp"
        android:maxWidth="280dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Decrypted message here..."
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:fontFamily="monospace"/>

        <View
            android:id="@+id/strengthBar"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:background="#00FF00"
            android:layout_marginTop="8dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/textSecurityBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛡 INTEGRITY CONFIRMED"
            android:textColor="#00FF00"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:layout_marginTop="4dp"
            android:visibility="gone"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/textTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:00"
            android:textColor="#444444"
            android:textSize="10sp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/textStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Encrypted • Delivered"
            android:textColor="#444444"
            android:textSize="9sp"
            android:fontFamily="monospace"/>
    </LinearLayout>

</LinearLayout>